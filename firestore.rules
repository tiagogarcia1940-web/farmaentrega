rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userPharmacyId() {
      return userDoc().pharmacyId == null ? 'farmaentrega-matriz' : userDoc().pharmacyId;
    }

    function samePharmacy(data) {
      return hasUserDoc() &&
             (data.pharmacyId == null ? 'farmaentrega-matriz' : data.pharmacyId) == userPharmacyId();
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "xtiaguinhox65@gmail.com" ||
        (hasUserDoc() && userDoc().role == 'admin')
      );
    }

    function hasRole(role) {
      return hasUserDoc() && userDoc().role == role;
    }

    function isStaff() {
      return isAdmin() || hasRole('pharmacist') || hasRole('logistics');
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (isStaff() && samePharmacy(resource.data))
      );

      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (isStaff() && request.resource.data.role == 'motoboy' && samePharmacy(request.resource.data))
      );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'pharmacyId'])
        ) ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == 'motoboy' &&
          request.resource.data.motoboyInviteToken is string &&
          exists(/databases/$(database)/documents/motoboyInvites/$(request.resource.data.motoboyInviteToken)) &&
          get(/databases/$(database)/documents/motoboyInvites/$(request.resource.data.motoboyInviteToken)).data.status == 'active' &&
          get(/databases/$(database)/documents/motoboyInvites/$(request.resource.data.motoboyInviteToken)).data.pharmacyId == request.resource.data.pharmacyId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'role', 'pharmacyId', 'status', 'motoboyInviteToken', 'updatedAt'
          ])
        )
      );

      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        (hasUserDoc() && resource.data.customerPhone == userDoc().phone) ||
        resource.data.motoboyId == request.auth.uid ||
        isAdmin() ||
        (isStaff() && samePharmacy(resource.data))
      );

      allow create: if isSignedIn() &&
        request.resource.data.status == 'pending' &&
        (
          (
            request.resource.data.customerId == request.auth.uid &&
            (
              request.resource.data.pharmacyId == null ||
              request.resource.data.pharmacyId == 'farmaentrega-matriz' ||
              exists(/databases/$(database)/documents/pharmacies/$(request.resource.data.pharmacyId))
            )
          ) ||
          isAdmin() ||
          (hasRole('pharmacist') && samePharmacy(request.resource.data))
        );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          samePharmacy(resource.data) &&
          samePharmacy(request.resource.data) &&
          hasRole('pharmacist') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'motoboyId', 'motoboyName', 'items', 'totalValue', 'change',
            'customerName', 'customerAddress', 'customerPhone', 'deliveryType', 'paymentMethod',
            'approvedAt', 'readyAt', 'updatedAt', 'cancellationReason'
          ])
        ) ||
        (
          samePharmacy(resource.data) &&
          samePharmacy(request.resource.data) &&
          hasRole('logistics') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'motoboyId', 'motoboyName', 'status', 'approvedAt', 'updatedAt'
          ])
        ) ||
        (
          samePharmacy(resource.data) &&
          samePharmacy(request.resource.data) &&
          resource.data.motoboyId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'inTransitAt', 'deliveredAt', 'updatedAt', 'location',
            'deliveryLocation', 'deliveryProof'
          ])
        )
      );

      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /counters/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
        (resource == null || request.resource.data.lastNumber >= resource.data.lastNumber);
      allow delete: if isAdmin();
    }

    match /pharmacies/{pharmacyId} {
      allow read: if true;
      allow create: if isAdmin() || (
        isStaff() &&
        request.resource.data.pharmacyId == pharmacyId &&
        request.resource.data.pharmacyId == userPharmacyId()
      );
      allow update: if isAdmin() || (
        isStaff() &&
        resource.data.pharmacyId == pharmacyId &&
        request.resource.data.pharmacyId == pharmacyId &&
        pharmacyId == userPharmacyId()
      );
      allow delete: if isAdmin();
    }

    match /motoboyInvites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (
        isStaff() &&
        request.resource.data.pharmacyId == userPharmacyId() &&
        request.resource.data.status == 'active'
      );
      allow update: if isAdmin() || (
        isSignedIn() &&
        (
          (isStaff() && resource.data.pharmacyId == userPharmacyId()) ||
          request.resource.data.lastLinkedUserId == request.auth.uid
        )
      );
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || (isStaff() && samePharmacy(request.resource.data));
      allow update: if isAdmin() || (isStaff() && samePharmacy(resource.data) && samePharmacy(request.resource.data));
      allow delete: if isAdmin() || (isStaff() && samePharmacy(resource.data));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
