rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userPharmacyId() {
      return request.auth.token.pharmacyId is string
        ? request.auth.token.pharmacyId
        : (userDoc().pharmacyId == null ? 'farmaentrega-matriz' : userDoc().pharmacyId);
    }

    function samePharmacy(data) {
      return isSignedIn() &&
             (request.auth.token.pharmacyId is string || hasUserDoc()) &&
             (data.pharmacyId == null ? 'farmaentrega-matriz' : data.pharmacyId) == userPharmacyId();
    }

    function isClaimAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.platformAdmin == true
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isClaimAdmin() ||
        request.auth.token.role == 'admin' ||
        (hasUserDoc() && userDoc().role == 'admin')
      );
    }

    function hasRole(role) {
      return isSignedIn() && (
        request.auth.token.role == role ||
        (hasUserDoc() && userDoc().role == role)
      );
    }

    function isStaff() {
      return isAdmin() || hasRole('pharmacist') || hasRole('logistics');
    }

    function isPublicStoreData(data) {
      return !('secret' in data) &&
             !('token' in data) &&
             !('apiKey' in data) &&
             !('privateKey' in data) &&
             !('password' in data);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (isStaff() && samePharmacy(resource.data))
      );

      allow create: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.uid == userId &&
          request.resource.data.email == request.auth.token.email &&
          (
            request.resource.data.role == 'client' ||
            (
              request.resource.data.role in ['pharmacist', 'motoboy'] &&
              request.resource.data.pharmacyId == 'pharmacy_' + request.auth.uid
            )
          ) &&
          request.resource.data.diff({}).affectedKeys().hasOnly([
            'uid', 'name', 'email', 'role', 'photoURL', 'phone', 'address',
            'status', 'pharmacyId', 'createdAt', 'updatedAt'
          ])
        ) ||
        (
          isStaff() &&
          request.resource.data.role == 'motoboy' &&
          samePharmacy(request.resource.data)
        )
      );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.pharmacyId == resource.data.pharmacyId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name', 'phone', 'address', 'photoURL', 'updatedAt'
          ])
        ) ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == 'motoboy' &&
          request.resource.data.motoboyInviteToken is string &&
          exists(/databases/$(database)/documents/motoboyInvites/$(request.resource.data.motoboyInviteToken)) &&
          get(/databases/$(database)/documents/motoboyInvites/$(request.resource.data.motoboyInviteToken)).data.status == 'active' &&
          get(/databases/$(database)/documents/motoboyInvites/$(request.resource.data.motoboyInviteToken)).data.pharmacyId == request.resource.data.pharmacyId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'role', 'pharmacyId', 'status', 'motoboyInviteToken', 'updatedAt'
          ])
        ) ||
        (
          isStaff() &&
          samePharmacy(resource.data) &&
          resource.data.role == 'motoboy' &&
          request.resource.data.role == 'client' &&
          request.resource.data.pharmacyId == null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'role', 'pharmacyId', 'status', 'motoboyInviteToken', 'updatedAt', 'unlinkedAt', 'unlinkedBy'
          ])
        )
      );

      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.motoboyId == request.auth.uid ||
        isAdmin() ||
        (isStaff() && samePharmacy(resource.data))
      );

      allow create: if isSignedIn() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.diff({}).affectedKeys().hasOnly([
          'orderCode', 'customerName', 'customerAddress', 'customerPhone',
          'customerId', 'items', 'totalValue', 'paymentMethod', 'change',
          'status', 'pharmacyId', 'deliveryType', 'createdAt', 'updatedAt'
        ]) &&
        (
          isAdmin() ||
          (hasRole('pharmacist') && samePharmacy(request.resource.data))
        );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          samePharmacy(resource.data) &&
          samePharmacy(request.resource.data) &&
          hasRole('pharmacist') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'motoboyId', 'motoboyName', 'items', 'totalValue', 'change',
            'customerName', 'customerAddress', 'customerPhone', 'deliveryType', 'paymentMethod',
            'approvedAt', 'readyAt', 'updatedAt', 'cancellationReason'
          ])
        ) ||
        (
          samePharmacy(resource.data) &&
          samePharmacy(request.resource.data) &&
          hasRole('logistics') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'motoboyId', 'motoboyName', 'status', 'approvedAt', 'updatedAt'
          ])
        ) ||
        (
          samePharmacy(resource.data) &&
          samePharmacy(request.resource.data) &&
          hasRole('motoboy') &&
          resource.data.motoboyId == request.auth.uid &&
          request.resource.data.motoboyId == resource.data.motoboyId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'inTransitAt', 'deliveredAt', 'updatedAt', 'location',
            'deliveryLocation', 'deliveryProof'
          ])
        )
      );

      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /counters/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() &&
        (resource == null || request.resource.data.lastNumber >= resource.data.lastNumber);
      allow delete: if isAdmin();
    }

    match /pharmacies/{pharmacyId} {
      allow read: if true;
      allow create: if isAdmin() || (
        isStaff() &&
        request.resource.data.pharmacyId == pharmacyId &&
        request.resource.data.pharmacyId == userPharmacyId()
      );
      allow update: if isAdmin() || (
        isStaff() &&
        resource.data.pharmacyId == pharmacyId &&
        request.resource.data.pharmacyId == pharmacyId &&
        pharmacyId == userPharmacyId()
      );
      allow delete: if isAdmin();
    }

    match /motoboyInvites/{inviteId} {
      allow read: if isAdmin() ||
        (
          isStaff() &&
          resource.data.pharmacyId == userPharmacyId()
        ) ||
        (
          isSignedIn() &&
          resource.data.status == 'active'
        );
      allow create: if isAdmin() || (
        isStaff() &&
        request.resource.data.pharmacyId == userPharmacyId() &&
        request.resource.data.status == 'active' &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.diff({}).affectedKeys().hasOnly([
          'token', 'pharmacyId', 'createdBy', 'status', 'createdAt'
        ])
      );
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.status == 'active' &&
        request.resource.data.pharmacyId == resource.data.pharmacyId &&
        request.resource.data.token == resource.data.token &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastLinkedUserId', 'lastLinkedAt'
        ]) &&
        request.resource.data.lastLinkedUserId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if docId in ['public', 'store'] && isPublicStoreData(resource.data);
      allow write: if isStaff() || isAdmin();
    }

    match /products/{productId} {
      allow read: if isPublicStoreData(resource.data);
      allow create: if isAdmin() || (isStaff() && samePharmacy(request.resource.data));
      allow update: if isAdmin() || (isStaff() && samePharmacy(resource.data) && samePharmacy(request.resource.data));
      allow delete: if isAdmin() || (isStaff() && samePharmacy(resource.data));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
